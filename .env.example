# Monday.com API tokens — naming aligned with ~/.monday_tokens convention.
MONDAY_GRAYSPACE_TOKEN=          # writes Capacity Engine, Process Recipe, Schedule
MONDAY_NEXIUUM_TOKEN=            # Phase 2 — reads/writes Nexiuum-side boards

# Webhook authentication — shared secret embedded in URL path
# (POST /webhook/monday/<secret>). Generate with: openssl rand -hex 32
MONDAY_WEBHOOK_SECRET=

# Engine identity for echo filtering — Monday user id the engine writes
# as. Auto-detected via { me { id } } at first webhook if left blank.
# Override only for tests or when running with a different account.
ENGINE_MONDAY_USER_ID=

# Monday boards
GRAY_SPACE_CAPACITY_ENGINE_BOARD=18413803163
GRAY_SPACE_PROCESS_RECIPE_BOARD=18414126054
GRAY_SPACE_SCHEDULE_BOARD=18413802995
GRAY_SPACE_BLEND_RECORDS_BOARD=18404836849

# Phase 2 — Nexiuum-side boards (optional, all-or-nothing).
# When all four are populated (token + 3 board IDs), the snapshot reader
# merges Capacity Engine + Process Recipe + Schedule rows from both
# accounts. Leave all blank/0 to keep Phase 1 (Gray Space only) behavior.
# Per Option B (2026-05-25): each instance keeps its own Schedule board;
# the unified Marey view fans across both via /schedule.json.
NEXIUUM_CAPACITY_ENGINE_BOARD=18414776125
NEXIUUM_PROCESS_RECIPE_BOARD=18414776199
NEXIUUM_SCHEDULE_BOARD=18414776220

# Timezone
FACTORY_TZ=America/Denver

# Polling sweep
POLLING_INTERVAL_MINUTES=15
DRIFT_THRESHOLD_MINUTES=15
DRIFT_SUPPRESSION_MINUTES=60

# Server
PORT=8002
LOG_LEVEL=INFO

# Monitoring (optional)
SENTRY_DSN=
